aws_region = "mx-central-1"
project_name = "retail-pos"
backend_image_tag = "latest"
instance_type = "t3.micro"
db_name = "postgres"
db_username = "postgres"
db_password = "ChangeMeStrongPassword123!"
db_instance_class = "db.t3.micro"
ssh_cidr = "0.0.0.0/0"
# key_name = "my-ec2-keypair"
# terraform_runner_principal_arn = "arn:aws:iam::123456789012:user/tu-usuario-terraform"

# Cambia a true si tu App Client debe usar secret hash.
generate_client_secret = false

# URLs opcionales para Hosted UI (si luego lo usas en frontend).
cognito_callback_urls = [
  "http://localhost:5173"
]

cognito_logout_urls = [
  "http://localhost:5173"
]
